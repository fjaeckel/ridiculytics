# Copy to .env and edit. This is the entire configuration surface for the
# production stack — there is no YAML file to touch.
#
#   cp .env.example .env
#   docker compose -f docker-compose.prod.yml up -d

# ── Required ────────────────────────────────────────────────────────────────

# Hostname serving the collector. DNS must point at this host before you issue
# a certificate. This is the value that goes in counter.js's data-host.
STATS_DOMAIN=stats.example.com

# Where Let's Encrypt sends expiry warnings.
CERTBOT_EMAIL=you@example.com

# Domains you are tracking, comma-separated. Origins default to
# https://<domain> and https://www.<domain>, so for the common case this is
# the only site variable you need.
RIDICULYTICS_SITES=example.com

# ── Certificates (opt-in) ───────────────────────────────────────────────────
#
# TLS is off by default and certbot does not run at all. Two variables control
# it, and they move together:
#
#   COMPOSE_PROFILES=tls   runs certbot (issuance + renewal loop)
#   NGINX_MODE=https       makes nginx serve TLS and redirect HTTP
#
# Bootstrap order matters. In https mode nginx refuses to start without a real
# certificate, so issue one while still in http mode:
#
#   1. leave both unset, `up -d`, point DNS at this host
#   2. COMPOSE_PROFILES=tls docker compose -f docker-compose.prod.yml \
#          run --rm certbot-init
#   3. uncomment both lines below, then `up -d` again
#
# Leaving TLS off is a legitimate end state if something in front of this host
# already terminates it — a cloud load balancer, Cloudflare, an existing edge
# proxy. Do not serve public traffic over plain HTTP otherwise: beacons travel
# in cleartext and HTTPS pages will block counter.js as mixed content.

#COMPOSE_PROFILES=tls
#NGINX_MODE=https

# Use Let's Encrypt staging for your first attempt. The production endpoint
# allows 5 failures per hostname per hour and a typo in STATS_DOMAIN burns one.
#CERTBOT_STAGING=1

# ── Per-site overrides ──────────────────────────────────────────────────────
#
# The site name becomes an infix, uppercased with every non-alphanumeric
# character replaced by an underscore:
#   example.com        -> SITE_EXAMPLE_COM
#   blog.example.co.uk -> SITE_BLOG_EXAMPLE_CO_UK

#RIDICULYTICS_SITE_EXAMPLE_COM_ORIGINS=https://example.com,https://www.example.com
#RIDICULYTICS_SITE_EXAMPLE_COM_CROSS_PATH_CAP=25
#RIDICULYTICS_SITE_EXAMPLE_COM_PATH_LABELS=country,referrer
#RIDICULYTICS_SITE_EXAMPLE_COM_UNIQUE_VISITORS_BY_PATH=true
#RIDICULYTICS_SITE_EXAMPLE_COM_HMAC_KEY=

# ── Cardinality ─────────────────────────────────────────────────────────────
#
# cross_path_cap is the one number that decides your Prometheus bill.
# Roughly, per site:  labels off ~900 series | 50 ~8,300 | 200 ~28,000

#RIDICULYTICS_PATH_CAP=200
#RIDICULYTICS_CROSS_PATH_CAP=50
#RIDICULYTICS_PATH_LABELS=country,referrer,source,medium,campaign,browser,os,device,screen,event
# Set to "-" or "none" to drop path labels entirely and take the ~900 figure.
#RIDICULYTICS_PATH_LABELS=none

# How often a value must be seen before it earns its own series. Raise it if a
# crawler is filling your __other__ bucket.
#RIDICULYTICS_ADMIT_MIN_COUNT=3

#RIDICULYTICS_SESSION_TTL=30m
#RIDICULYTICS_DECAY_AFTER=168h

# ── Geolocation ─────────────────────────────────────────────────────────────
#
# dbip | maxmind | none. DB-IP Lite is CC-BY-4.0 and needs no signup; build
# with WITH_GEO=1 to bake it into the image, or mount your own into GEO_DIR.
# If you use DB-IP Lite, its licence requires attribution — link db-ip.com.

#WITH_GEO=1
#GEO_DIR=./geo
#RIDICULYTICS_GEO_PROVIDER=dbip
#RIDICULYTICS_GEO_CITY_DB=/var/lib/ridiculytics/dbip-city-lite.mmdb
#RIDICULYTICS_GEO_ASN_DB=/var/lib/ridiculytics/dbip-asn-lite.mmdb

# ── Tuning ──────────────────────────────────────────────────────────────────

#RIDICULYTICS_WORKERS=4
#RIDICULYTICS_QUEUE_SIZE=8192
#RIDICULYTICS_RATE_PER_MIN=600
#RIDICULYTICS_SALT_ROTATE=24h
#RIDICULYTICS_SERVE_COUNTER_JS=true

# Host port for the metrics endpoint. Bound to 127.0.0.1 only — a Prometheus
# on this host can scrape it, the internet cannot.
#METRICS_PORT=9090
