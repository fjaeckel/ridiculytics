{
  "name": "ridiculytics",
  "version": "1.0.1",
  "description": "Tiny, cookieless analytics script for the ridiculytics collector.",
  "main": "web/counter.js",
  "files": ["web/counter.js", "web/counter.min.js", "LICENSE-MIT"],
  "scripts": {
    "build": "esbuild web/counter.js --minify --target=es5 --outfile=web/counter.min.js --legal-comments=none",
