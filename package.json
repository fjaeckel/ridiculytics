  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "keywords": ["analytics", "privacy", "prometheus", "cookieless", "self-hosted"],
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/fjaeckel/ridiculytics.git" }
}
